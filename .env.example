# LabelWatch — environment template
# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase (server-side — service role key, NEVER expose to client)
# Used by app/api/signup/route.ts to persist waitlist entries into `labelwatch_signups`.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (added in Eng-2 — leave blank for now)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_TEAM=price_...

# openFDA poller cron secret. Used by app/api/cron/poll/route.ts.
# UptimeRobot monitor hits: https://label.watch/api/cron/poll?cron_secret=<value>
# Generate: openssl rand -hex 32
CRON_SECRET=

# Resend (contact-form notifications)
# Used by app/api/contact/route.ts to email support@novique.ai when a
# customer submits the contact form. Domain `label.watch` must be verified
# in the Resend dashboard before the configured CONTACT_EMAIL_FROM works.
RESEND_API_KEY=
CONTACT_EMAIL_TO=support@novique.ai
CONTACT_EMAIL_FROM=LabelWatch <noreply@label.watch>

# Listing Copy Audit (lcaudit) — bead infrastructure-sl26.
# Anthropic API key for Claude Vision (SFP image extract) + text extraction.
# 1Password: "Anthropic API Key" in System vault.
ANTHROPIC_API_KEY=
# HS256 secret used to sign customer audit-access tokens (32+ bytes recommended).
# Generate: openssl rand -hex 32
LABELWATCH_AUDIT_TOKEN_SECRET=
# Public URL used in audit-access emails. Defaults to https://label.watch.
LABELWATCH_PUBLIC_URL=https://label.watch
# Supabase Storage bucket name for SFP images. Service-role-only access.
LABELWATCH_AUDIT_BUCKET=audit-sfp-images
