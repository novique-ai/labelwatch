# LabelWatch — environment template
# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase (server-side — service role key, NEVER expose to client)
# Used by app/api/signup/route.ts to persist waitlist entries into `labelwatch_signups`.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (added in Eng-2 — leave blank for now)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_TEAM=price_...

# openFDA poller cron secret. Used by app/api/cron/poll/route.ts.
# UptimeRobot monitor hits: https://label.watch/api/cron/poll?cron_secret=<value>
# Generate: openssl rand -hex 32
CRON_SECRET=

# Resend (contact-form notifications)
# Used by app/api/contact/route.ts to email support@novique.ai when a
# customer submits the contact form. Domain `label.watch` must be verified
# in the Resend dashboard before the configured CONTACT_EMAIL_FROM works.
RESEND_API_KEY=
CONTACT_EMAIL_TO=support@novique.ai
CONTACT_EMAIL_FROM=LabelWatch <noreply@label.watch>
